# Copy this file to `.env` and replace the placeholder values.

# OpenRouter embeddings
OPENROUTER_API_KEY=replace-with-openrouter-api-key
OPENROUTER_HTTP_REFERER=https://your-app.example
OPENROUTER_APP_TITLE=data-contract-enforcer

# LangSmith tracing and export
LANGSMITH_API_KEY=replace-with-langsmith-api-key
LANGSMITH_ENDPOINT=https://api.smith.langchain.com
LANGSMITH_PROJECT=replace-with-week3-langsmith-project-name

# Expected export target for real traces
LANGSMITH_RUNS_PATH=outputs/traces/runs.jsonl
